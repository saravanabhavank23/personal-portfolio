{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/about.html",
      "dest": "/frontend/about.html"
    },
    {
      "src": "/projects.html",
      "dest": "/frontend/projects.html"
    },
    {
      "src": "/contact.html",
      "dest": "/frontend/contact.html"
    },
    {
      "src": "/style.css",
      "dest": "/frontend/style.css"
    },
    {
      "src": "/script.js",
      "dest": "/frontend/script.js"
    },
    {
      "src": "/(.*\\.(png|jpg|jpeg|svg|gif|webp))",
      "dest": "/frontend/$1"
    }
  ]
}